{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "JwtSettings": {
    "SecretKey": "__SET_VIA_ENV_VAR_JWT_SECRET_KEY_OR_DOTNET_USER_SECRETS__",
    "Issuer": "PasswordlessApi",
    "Audience": "PasswordlessApiUsers",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "AllowedHosts": "*",
  "ApiSettings": {
    "BaseUrl": "http://localhost:5000",
    "ServerName": "PasswordlessApi",
    "AllowCredentials": true,
    "AllowedOrigins": [
      "http://localhost:5115"
    ]
  },
  "SecuritySettings": {
    "MaxLoginAttempts": 5,
    "LoginLockoutDurationMinutes": 15,
    "MaxConcurrentSessions": 5,
    "EnableSuspiciousActivityDetection": true,
    "ForceReauthOnLocationChange": true
  },
  "RateLimiting": {
    "Login": { "PermitLimit": 5, "WindowMinutes": 5 },
    "RefreshToken": { "PermitLimit": 30, "WindowMinutes": 1 },
    "General": { "PermitLimit": 100, "WindowMinutes": 1 },
    "Registration": { "PermitLimit": 5, "WindowMinutes": 15 }
  },
  "ConnectionStrings": {
    "DefaultConnection": "__SET_VIA_ENV_VAR_DB_CONNECTION_STRING__"
  }
}
