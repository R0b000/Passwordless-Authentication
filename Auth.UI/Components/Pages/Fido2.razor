@page "/fido2"
@page "/fido2/{UserIdParam:int}"
@namespace Auth.UI.Components.Pages
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer

<PageTitle>Passkey sign-in - Passwordless Auth</PageTitle>

<div class="auth-shell">
    <div class="auth-card">
        <div class="auth-brand">
            <Icon Name="shield" Size="Icon.IconSize.Small" />
            <span>Passwordless Auth</span>
        </div>

        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            <div class="alert alert-danger" role="alert">@StatusMessage</div>
        }

        @if (State == PasskeyState.Idle)
        {
            @if (!IsEmailResolved)
            {
                <div class="auth-hero">
                    <div class="passkey-badge">
                        <Icon Name="fingerprint" Size="Icon.IconSize.Large" />
                    </div>
                    <h1 class="auth-title">Sign in with a passkey</h1>
                    <p class="auth-subtitle">Use your device biometric or a security key — no password needed.</p>
                </div>

                <div class="mb-3 text-start">
                    <label class="form-label font-weight-bold">Email address</label>
                    <InputText class="form-control" @bind-Value="Email" placeholder="you@example.com" />
                    <div class="form-text text-muted">Enter the email address linked to your account.</div>
                </div>

                <button class="btn btn-primary w-100" @onclick="@ResolveAccountAsync" type="button">
                    Continue
                </button>

                <div class="auth-footer-link mt-3">
                    <a class="btn btn-link" href="/">Use password instead</a>
                </div>
            }
            else
            {
                <div class="auth-hero">
                    <div class="passkey-badge">
                        <Icon Name="fingerprint" Size="Icon.IconSize.Large" />
                    </div>
                    <h1 class="auth-title">Choose your method</h1>
                    <p class="auth-subtitle">Verify your identity to complete sign-in.</p>
                </div>

                <div class="card mb-3">
                    <div class="card-body text-start d-flex justify-content-between align-items-center py-2 px-3">
                        <div>
                            <div class="small text-muted">Signing in as</div>
                            <strong>@ResolvedUsername</strong> <span class="text-muted">(@Email)</span>
                        </div>
                        @if (UserIdParam == null)
                        {
                            <button class="btn btn-sm btn-link text-decoration-none" @onclick="@ResetEmailLookup" type="button">Change</button>
                        }
                    </div>
                </div>

                <button class="passkey-btn" @onclick="@(() => StartAssertionAsync())" type="button">
                    <Icon Name="fingerprint" Size="Icon.IconSize.Small" />
                    Sign in with a passkey
                </button>

                <div class="auth-options mt-2">
                    <button class="btn btn-outline-secondary" @onclick="@(() => StartAssertionAsync("cross-platform"))" type="button">
                        <Icon Name="usb" Size="Icon.IconSize.Small" /> Use a security key
                    </button>
                    @if (UserIdParam == null)
                    {
                        <button class="btn btn-link" @onclick="@ResetEmailLookup" type="button">Use a different email</button>
                    }
                    else
                    {
                        <a class="btn btn-link" href="/">Use password instead</a>
                    }
                </div>
            }
        }
        else
        {
            <div class="auth-hero">
                <div class="passkey-badge">
                    <Icon Name="fingerprint" Size="Icon.IconSize.Large" />
                </div>
                <h1 class="auth-title">Verify it's you</h1>
            </div>
        }

        <div class="auth-status @(State == PasskeyState.Awaiting || State == PasskeyState.Requesting ? "is-awaiting" : State == PasskeyState.Success ? "is-success" : State == PasskeyState.Error ? "is-error" : "")"
             role="status" aria-live="polite">
            @if (State == PasskeyState.Awaiting || State == PasskeyState.Requesting || State == PasskeyState.Verifying)
            {
                <div class="biometric-ring @(State == PasskeyState.Verifying ? "is-static" : "")">
                    <Icon Name="fingerprint" Size="Icon.IconSize.Small" />
                </div>
                <p class="auth-status-text">
                    @(State == PasskeyState.Requesting ? "Preparing your passkey…"
                        : State == PasskeyState.Verifying ? "Checking your passkey…"
                        : "Waiting for your fingerprint, face, or security key…")
                </p>
                <p class="auth-status-detail">@StatusDetail</p>
            }
            else if (State == PasskeyState.Success)
            {
                <div class="biometric-ring is-static" style="border-color: rgba(46,139,87,.35); color: var(--ui-success);">
                    <Icon Name="check" Size="Icon.IconSize.Small" />
                </div>
                <p class="auth-status-text">Signed in</p>
                <p class="auth-status-detail">@StatusDetail</p>
            }
            else if (State == PasskeyState.Error)
            {
                <div class="biometric-ring is-static" style="border-color: rgba(192,57,43,.35); color: var(--ui-danger);">
                    <Icon Name="alert-triangle" Size="Icon.IconSize.Small" />
                </div>
                <p class="auth-status-text">Passkey sign-in couldn't be completed</p>
                <p class="auth-status-detail">@StatusDetail</p>
            }
        </div>

        @if (State == PasskeyState.Error)
        {
            <div class="auth-options">
                <button class="btn btn-primary" @onclick="@(() => StartAssertionAsync())" type="button">
                    <Icon Name="fingerprint" Size="Icon.IconSize.Small" /> Try again
                </button>
                <button class="btn btn-outline-secondary" @onclick="@(() => StartAssertionAsync("cross-platform"))" type="button">
                    <Icon Name="usb" Size="Icon.IconSize.Small" /> Use a security key
                </button>
            </div>
            <div class="auth-footer-link">
                @if (UserIdParam == null)
                {
                    <button class="btn btn-link" @onclick="@ResetEmailLookup" type="button">Try another account</button>
                }
                <a class="btn btn-link" href="/">Back to sign in</a>
            </div>
        }

        @if (!string.IsNullOrEmpty(AssertionOptions))
        {
            <details class="mt-3">
                <summary class="text-muted small">Advanced: assertion options from server</summary>
                <pre class="border rounded p-2 bg-light small mt-2">@AssertionOptions</pre>
            </details>
        }
    </div>
</div>
