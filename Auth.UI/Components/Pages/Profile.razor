@page "/profile"
@namespace Auth.UI.Components.Pages
@layout LoginLayout
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using Auth.UI.Components.UI.Menu
@rendermode InteractiveServer

<PageTitle>Profile - Passwordless Auth</PageTitle>

<div class="app-shell">
    <aside class="app-sidebar">
        <div class="app-brand">
            <Icon Name="shield" Size="Icon.IconSize.Small" />
            <span>Passwordless Auth</span>
        </div>

        <Menu Items="MenuItems" OnAction="OnMenuAction" />
    </aside>

    <div class="app-main">
        <header class="app-header">
            <h1 class="app-header-title">Profile</h1>

            <div class="app-account">
                <button type="button" class="app-account-badge" @onclick="ToggleAccountMenu" aria-haspopup="true" aria-expanded="@AccountMenuOpen">
                    <span class="app-account-avatar">@AccountInitial</span>
                    <span>@(CurrentUser?.Username ?? "Account")</span>
                </button>

                @if (AccountMenuOpen)
                {
                    <div class="app-dropdown-backdrop" @onclick="CloseAccountMenu"></div>
                    <div class="app-account-dropdown" role="menu">
                        <button type="button" class="app-dropdown-item" role="menuitem" @onclick="LogoutAsync">
                            <Icon Name="x" Size="Icon.IconSize.Small" />
                            <span>Logout</span>
                        </button>
                    </div>
                }
            </div>
        </header>

        <main class="app-content">
            @if (!string.IsNullOrEmpty(StatusMessage))
            {
                <div class="alert @(Succeeded ? "alert-success" : "alert-danger") mb-3" role="alert">@StatusMessage</div>
            }

            <div class="app-profile-card">
                <h5 class="mb-3">Authenticated identity</h5>
                @if (CurrentUser is not null)
                {
                    <p class="mb-1">User Id: <strong>@CurrentUser.UserId</strong></p>
                    <p class="mb-1">Username: <strong>@CurrentUser.Username</strong></p>
                    <p class="mb-1">Email: <strong>@CurrentUser.Email</strong></p>
                    <p class="mb-0">Status: <span class="badge bg-success">@CurrentUser.Message</span></p>
                }
                else
                {
                    <p class="text-muted mb-0">No authenticated identity. Please sign in.</p>
                }

                <div class="app-profile-actions">
                    <button class="btn btn-outline-secondary" @onclick="@LoadProfileAsync">Refresh</button>
                    @if (CurrentUser is not null)
                    {
                        <button class="btn btn-primary" @onclick="@(() => RegisterPasskeyAsync(CurrentUser.UserId, CurrentUser.Username))" type="button">Register Passkey</button>
                    }
                </div>
            </div>
        </main>
    </div>
</div>
