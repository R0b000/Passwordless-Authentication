@page "/profile"
@page "/account/profile"
@namespace Auth.UI.Components.Pages.Customer.Account.Profile
@layout AccountLayout
@using Auth.UI.Components.UI.Toaster
@using Auth.UI.Components.UI.Upload
@using Auth.UI.Components.UI.Tag

<PageTitle>Profile - Passwordless Auth</PageTitle>

<div class="account-card">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h3>Profile</h3>
            <div class="section-sub">Manage your personal information and account overview.</div>
        </div>
        @if (!EditMode)
        {
            <Button Variant="Button.ButtonVariant.Primary" IconName="edit" OnClick="EnterEdit">Edit profile</Button>
        }
    </div>

    @if (!string.IsNullOrEmpty(StatusMessage))
    {
        <div class="alert @(Succeeded ? "alert-success" : "alert-danger") mb-3" role="alert">@StatusMessage</div>
    }

    <div class="avatar-block">
        <div class="avatar-img">@Initials</div>
        <div>
            <div class="fw-semibold">Profile picture</div>
            <div class="text-muted small mb-2">JPG or PNG, up to 5 MB.</div>
            @if (EditMode)
            {
                <Upload Accept="image/*" MaxSize="5242880" OnFileSelected="OnAvatarSelected" />
            }
        </div>
    </div>

    @if (EditMode)
    {
        <div class="account-grid">
            <div class="account-field">
                <label>Display name</label>
                <input class="form-control" @bind="Model!.DisplayName" />
            </div>
            <div class="account-field">
                <label>Username</label>
                <input class="form-control" @bind="Model!.Username" />
            </div>
            <div class="account-field">
                <label>Email</label>
                <input class="form-control" type="email" @bind="Model!.Email" />
            </div>
            <div class="account-field">
                <label>Phone</label>
                <input class="form-control" @bind="Model!.Phone" />
            </div>
            <div class="account-field" style="grid-column: 1 / -1;">
                <label>Bio</label>
                <textarea class="form-control" rows="3" @bind="Model!.Bio"></textarea>
            </div>
        </div>
        <div class="account-actions">
            <Button Variant="Button.ButtonVariant.Primary" OnClick="SaveAsync">Save changes</Button>
            <Button Variant="Button.ButtonVariant.Secondary" Outline="true" OnClick="CancelEdit">Cancel</Button>
        </div>
    }
    else
    {
        <div class="profile-meta">
            <div class="meta-item"><div class="meta-label">Display name</div><div class="meta-value">@Model?.DisplayName</div></div>
            <div class="meta-item"><div class="meta-label">Username</div><div class="meta-value">@Model?.Username</div></div>
            <div class="meta-item"><div class="meta-label">Email</div><div class="meta-value">@Model?.Email</div></div>
            <div class="meta-item"><div class="meta-label">Phone</div><div class="meta-value">@Model?.Phone</div></div>
            <div class="meta-item" style="grid-column: 1 / -1;"><div class="meta-label">Bio</div><div class="meta-value">@Model?.Bio</div></div>
            <div class="meta-item"><div class="meta-label">Date joined</div><div class="meta-value">@Model?.DateJoined.ToString("MMM d, yyyy")</div></div>
            <div class="meta-item"><div class="meta-label">Last active</div><div class="meta-value">@Model?.LastActive.ToString("g")</div></div>
            <div class="meta-item"><div class="meta-label">Last login</div><div class="meta-value">@(Model?.LastLoginAt?.ToString("g") ?? "—")</div></div>
            <div class="meta-item"><div class="meta-label">Last login IP</div><div class="meta-value">@(Model?.LastLoginIp ?? "—")</div></div>
            <div class="meta-item"><div class="meta-label">Account status</div><div class="meta-value">
                <Tag Variant="@(Model?.AccountStatus == "active" ? Tag.TagVariant.Success : Tag.TagVariant.Danger)">@Model?.AccountStatus</Tag>
            </div></div>
        </div>
    }
</div>

<Toaster Position="ToastPosition.TopRight" />
