@page "/account/activity"
@namespace Auth.UI.Components.Pages.Customer.Account.Activity
@layout AccountLayout
@using Auth.UI.Components.UI.Toaster
@using Auth.UI.Components.UI.Datepicker
@using Auth.UI.Components.UI.Timeline

<PageTitle>Activity Log - Passwordless Auth</PageTitle>

<div class="account-card">
    <h3>Security Activity Log</h3>
    <div class="section-sub">A chronological record of security-relevant events on your account.</div>

    <div class="activity-filters">
        <div class="filter-item">
            <label>From</label>
            <Datepicker SelectedDate="@Query.From" SelectedDateChanged="v => Query.From = v" />
        </div>
        <div class="filter-item">
            <label>To</label>
            <Datepicker SelectedDate="@Query.To" SelectedDateChanged="v => Query.To = v" />
        </div>
        <div class="filter-item">
            <label>Activity type</label>
            <select class="form-control" @bind="Query.Type">
                <option value="all">All</option>
                <option value="login">Login</option>
                <option value="logout">Logout</option>
                <option value="password_change">Password change</option>
                <option value="settings_update">Settings update</option>
                <option value="2fa">Two-factor</option>
                <option value="login_failed">Failed login</option>
            </select>
        </div>
        <div class="filter-item" style="flex: 1; min-width: 200px;">
            <label>Search</label>
            <input class="form-control" placeholder="Search description, device or IP" @bind="Query.Search" />
        </div>
        <div class="filter-item">
            <Button Variant="Button.ButtonVariant.Primary" IconName="filter" OnClick="ApplyFiltersAsync">Apply</Button>
        </div>
        <div class="filter-item">
            <Button Variant="Button.ButtonVariant.Secondary" Outline="true" OnClick="ResetFiltersAsync">Reset</Button>
        </div>
    </div>

    @if (Entries.Count == 0)
    {
        <div class="empty-state">No activity matches your filters.</div>
    }
    else
    {
        <Timeline Items="@TimelineItems" />
    }
</div>

<Toaster Position="ToastPosition.TopRight" />
