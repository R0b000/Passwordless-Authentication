@page "/account/sessions"
@namespace Auth.UI.Components.Pages.Customer.Account.Sessions
@layout AccountLayout
@using Auth.UI.Components.UI.Toaster
@using Auth.UI.Components.UI.Icons
@using Auth.UI.Components.UI.Tag
@using Auth.UI.Shared.Components.Toaster

<PageTitle>Active Sessions - Passwordless Auth</PageTitle>

<div class="account-card">
    <h3>Active Sessions &amp; Devices</h3>
    <div class="section-sub">Review the devices signed in to your account and revoke any you don't recognise.</div>

    <div class="session-count">
        <strong>@SessionItems.Count</strong> active @(SessionItems.Count == 1 ? "session" : "sessions")
    </div>

    @if (SessionItems.Count >= 3)
    {
        <div class="alert alert-warning mb-3" role="alert">
            You've reached the concurrent session limit. Consider signing out of unused devices.
        </div>
    }

    @if (SessionItems.Count == 0)
    {
        <div class="empty-state">No active sessions.</div>
    }
    else
    {
        @foreach (var s in SessionItems)
        {
            <div class="session-card @(s.IsCurrent ? "is-current" : "")">
                <div class="session-icon">
                    <Icon Name="@DeviceIcon(s.DeviceType)" Size="Icon.IconSize.Medium" />
                </div>
                <div class="session-body">
                    <div class="session-title">
                        <span>@s.Browser</span>
                        @if (s.IsCurrent)
                        {
                            <Tag Variant="Tag.TagVariant.Success">Current device</Tag>
                        }
                    </div>
                    <div class="session-meta">
                        <span>@s.Os</span>
                        <span>@s.Location</span>
                        <span>@s.IpAddress</span>
                        <span>Active @s.LastActive.ToString("g")</span>
                    </div>
                </div>
                @if (!s.IsCurrent)
                {
                    <Button Variant="Button.ButtonVariant.Danger" Size="Button.ButtonSize.Small" Outline="true" OnClick="@(() => RevokeAsync(s.Id))">Revoke</Button>
                }
            </div>
        }
    }

    <div class="account-actions">
        <Button Variant="Button.ButtonVariant.Danger" Outline="true" OnClick="RevokeOthersAsync">Log out of all other devices</Button>
        <Button Variant="Button.ButtonVariant.Danger" OnClick="RevokeAllAsync">Log out of all devices</Button>
    </div>
</div>

<Toaster Position="ToastPosition.TopRight" />
