@page "/verify-device"
@namespace Auth.UI.Components.Pages.Shared
@layout LoginLayout
@using Auth.UI.Components.UI.Toaster
@using Auth.UI.Components.UI.Icons

<PageTitle>Verify device - Passwordless Auth</PageTitle>

<section class="lp-panel">
    <div class="lp-card">
        <h1 class="lp-title">Verify this device</h1>
        <p class="lp-sub">We detected a sign-in from a new device. Enter the code we sent to confirm it's you.</p>

        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            <div class="lp-alert @(Succeeded ? "lp-alert-success" : "lp-alert-danger")" role="alert">@StatusMessage</div>
        }

        <div class="lp-field">
            <label class="lp-label" for="vd-code">Verification code</label>
            <div class="lp-input">
                <Icon Name="key" Size="Icon.IconSize.Small" />
                <input id="vd-code" class="lp-control" @bind="Code" placeholder="123456" />
            </div>
        </div>

        <label class="lp-check" style="display:flex; gap:.5rem; align-items:center; margin:.5rem 0 1rem;">
            <input type="checkbox" @bind="TrustDevice" /> Trust this device for 30 days
        </label>

        <Button Variant="Button.ButtonVariant.Primary" Block="true" OnClick="VerifyAsync">Verify device</Button>
        <Button Variant="Button.ButtonVariant.Secondary" Outline="true" Block="true" OnClick="SendCodeAsync" Style="margin-top:.6rem;">Resend code</Button>

        <div class="lp-divider"><span>or</span></div>
        <p class="text-center mb-0"><a href="/login">Back to sign in</a></p>
    </div>
</section>

<Toaster Position="ToastPosition.TopRight" />
