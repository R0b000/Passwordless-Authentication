@page "/showcase"
@namespace Auth.UI.Components.Pages.Shared.Showcase
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using static Microsoft.AspNetCore.Components.Web.RenderMode

<PageTitle>UI Component Library</PageTitle>

<Breadcrumb Items="@BreadcrumbItems" />

<h2 class="mt-3 mb-4">UI Component Library</h2>

<section class="mb-5">
    <h4>Buttons</h4>
    <div class="d-flex flex-wrap gap-2">
        <Button Variant="Button.ButtonVariant.Primary" OnClick="@(() => Notify("Primary clicked"))">Primary</Button>
        <Button Variant="Button.ButtonVariant.Success" IconName="check">Success</Button>
        <Button Variant="Button.ButtonVariant.Danger" Outline="true">Danger Outline</Button>
        <Button Variant="Button.ButtonVariant.Warning" Size="Button.ButtonSize.Large">Large</Button>
        <Button Variant="Button.ButtonVariant.Secondary" Disabled="true">Disabled</Button>
    </div>
</section>

<section class="mb-5">
    <h4>Modal &amp; Confirmation</h4>
    <div class="d-flex gap-2">
        <Button Variant="Button.ButtonVariant.Primary" OnClick="OpenModal">Open Modal</Button>
        <Button Variant="Button.ButtonVariant.Danger" OnClick="OpenConfirm">Open Confirmation</Button>
    </div>

    <Modal @ref="_modal" Title="Create Item" Size="ModalSize.Large"
           SubmitText="Save" OnSubmit="SaveAsync">
        <ChildContent>
            <p>This is a reusable modal built entirely with SVG icons.</p>
            <input class="form-control" placeholder="Item name" @bind="ItemName" />
        </ChildContent>
    </Modal>

    <ConfirmationModal @ref="_confirm" Title="Delete item"
                       Message="Are you sure you want to delete this item?"
                       OnConfirm="ConfirmedAsync" OnDecline="DeclinedAsync" />
</section>

<section class="mb-5">
    <h4>Autocomplete Select</h4>
    <div class="d-flex flex-wrap gap-3 align-items-end">
        <div>
            <div class="form-label">With search + All</div>
            <AutocompleteSelect Data="@Departments" EnableSearch="true" AllSelector="true"
                                SelectedId="@SelectedDept" SelectedIdChanged="OnDeptChanged" />
        </div>
        <div>
            <div class="form-label">Plain list</div>
            <AutocompleteSelect Data="@Departments" EnableSearch="false" AllSelector="false"
                                Placeholder="Pick department" />
        </div>
    </div>
    <p class="mt-2 text-muted">Selected id: @SelectedDept</p>
</section>

<section class="mb-5">
    <h4>Table (pagination, filtering, column toggle)</h4>
    <Table Items="@People" Columns="@Columns" PageSize="5" />
</section>

<section class="mb-5">
    <h4>Graphs</h4>
    <div class="row g-3">
        <div class="col-md-6"><Graph Data="@ChartData" XAxis="Label" YAxis="Value" Title="Line" Type="GraphType.Line" /></div>
        <div class="col-md-6"><Graph Data="@ChartData" XAxis="Label" YAxis="Value" Title="Bar" Type="GraphType.Bar" /></div>
        <div class="col-md-6"><Graph Data="@ChartData" XAxis="Label" YAxis="Value" Title="Pie" Type="GraphType.Pie" /></div>
        <div class="col-md-6"><Graph Data="@ChartData" XAxis="Label" YAxis="Value" Title="Heatmap" Type="GraphType.Heatmap" /></div>
    </div>
</section>

<section class="mb-5">
    <h4>Menu</h4>
    <Menu Items="@MenuItems" OnAction="OnMenuAction" />
</section>

<section class="mb-5">
    <h4>Pagination</h4>
    <Pagination TotalPages="10" CurrentPage="@PaginationPage" CurrentPageChanged="OnPaginationPageChanged" />
</section>

<section class="mb-5">
    <h4>Steps</h4>
    <Steps Items="@StepItems" ActiveIndex="@StepActiveIndex" />
    <div class="d-flex gap-2 mt-3">
        <Button Variant="Button.ButtonVariant.Secondary" Size="Button.ButtonSize.Small" OnClick="PrevStep">Previous</Button>
        <Button Variant="Button.ButtonVariant.Primary" Size="Button.ButtonSize.Small" OnClick="NextStep">Next</Button>
    </div>
</section>

<section class="mb-5">
    <h4>Tabs</h4>
    <Tabs TabItems="@TabItems" ActiveTab="@ActiveTab" ActiveTabChanged="OnTabChanged">
        <ChildContent>
            <div class="p-2">
                @ActiveTab.Content
            </div>
        </ChildContent>
    </Tabs>
</section>

<section class="mb-5">
    <h4>Checkbox</h4>
    <div class="d-flex flex-column gap-2">
        <Checkbox Checked="@CheckboxChecked" CheckedChanged="OnCheckboxChanged">Default checkbox</Checkbox>
        <Checkbox Checked="true" Disabled="true">Disabled checked</Checkbox>
        <Checkbox Checked="false" Disabled="true">Disabled unchecked</Checkbox>
    </div>
</section>

<section class="mb-5">
    <h4>Datepicker</h4>
    <div class="d-flex flex-wrap gap-3">
        <div>
            <div class="form-label">Input only</div>
            <Datepicker SelectedDate="@DatepickerValue" SelectedDateChanged="OnDatepickerChanged" />
        </div>
        <div>
            <div class="form-label">With popup</div>
            <Datepicker SelectedDate="@DatepickerPopupValue" SelectedDateChanged="OnDatepickerPopupChanged" Popup="true" />
        </div>
    </div>
</section>

<section class="mb-5">
    <h4>Form</h4>
    <Form Model="@FormModel" FormName="showcase-form" OnValidSubmit="OnFormValidSubmit" SubmitText="Save" CancelText="Reset" ShowCancel="true">
        <ChildContent>
            <div class="ui-form-group">
                <label class="ui-form-label">Name</label>
                <input class="form-control" @bind="FormModel.Name" />
            </div>
            <div class="ui-form-group">
                <label class="ui-form-label">Email</label>
                <input class="form-control" @bind="FormModel.Email" />
            </div>
        </ChildContent>
    </Form>
</section>

<section class="mb-5">
    <h4>Radio</h4>
    <div class="d-flex flex-column gap-2">
        @foreach (var option in RadioOptions)
        {
            <Radio GroupName="@RadioGroup" Value="@option" SelectedValue="@RadioSelected" SelectedValueChanged="OnRadioChanged">
                @option
            </Radio>
        }
    </div>
</section>

<section class="mb-5">
    <h4>Rate</h4>
    <div class="d-flex flex-column gap-2">
        <Rate CurrentValue="@RateValue" CurrentValueChanged="OnRateChanged" ShowText="true" />
        <Rate CurrentValue="@RateValue" Disabled="true" />
    </div>
</section>

<section class="mb-5">
    <h4>Slider</h4>
    <div class="row g-3">
        <div class="col-md-6">
            <Slider Min="0" Max="100" Value="@SliderValue" ValueChanged="OnSliderChanged" ShowSteps="true" Step="10" />
        </div>
        <div class="col-md-6">
            <Slider Min="0" Max="1000" Value="@SliderValue2" ValueChanged="OnSlider2Changed" Step="50" />
        </div>
    </div>
</section>

<section class="mb-5">
    <h4>Switch</h4>
    <div class="d-flex flex-column gap-2">
        <Switch Checked="@SwitchChecked" CheckedChanged="OnSwitchChanged" Label="Notifications" />
        <Switch Checked="true" Disabled="true" Label="Disabled on" />
        <Switch Checked="false" Disabled="true" Label="Disabled off" />
    </div>
</section>

<section class="mb-5">
    <h4>TimePicker</h4>
    <div class="d-flex flex-wrap gap-3">
        <div>
            <div class="form-label">Input only</div>
            <TimePicker SelectedTime="@TimepickerValue" SelectedTimeChanged="OnTimepickerChanged" />
        </div>
        <div>
            <div class="form-label">With popup</div>
            <TimePicker SelectedTime="@TimepickerPopupValue" SelectedTimeChanged="OnTimepickerPopupChanged" Popup="true" />
        </div>
    </div>
</section>

<section class="mb-5">
    <h4>Upload</h4>
    <Upload Multiple="true" MaxSize="5242880" OnFileSelected="OnUploadSelected" OnFileRemoved="OnUploadRemoved" />
</section>

<section class="mb-5">
    <h4>Calendar</h4>
    <div class="d-flex flex-wrap gap-3">
        <div>
            <div class="form-label">Select a date</div>
            <Calendar SelectedDate="@CalendarValue" SelectedDateChanged="OnCalendarChanged" ViewDate="@CalendarViewDate" />
        </div>
    </div>
</section>

<section class="mb-5">
    <h4>Card</h4>
    <div class="row g-3">
        <div class="col-md-4">
            <Card Title="Simple Card" Text="This is a basic card example." />
        </div>
        <div class="col-md-4">
            <Card Title="Card with footer" Text="Content goes here.">
                <Footer>
                    <Button Variant="Button.ButtonVariant.Primary" Size="Button.ButtonSize.Small">Action</Button>
                </Footer>
            </Card>
        </div>
        <div class="col-md-4">
            <Card Title="Card with image" Text="Beautiful scenery." ImageUrl="https://picsum.photos/seed/card/400/160" ImageAlt="Demo" />
        </div>
    </div>
</section>

<section class="mb-5">
    <h4>Carousel</h4>
    <Carousel Slides="@CarouselSlides" ActiveIndex="@CarouselIndex" ActiveIndexChanged="OnCarouselIndexChanged" AutoPlay="false" />
</section>

<section class="mb-5">
    <h4>Collapse</h4>
    <Collapse Items="@CollapseItems" Accordion="true" />
</section>

<section class="mb-5">
    <h4>Tag</h4>
    <div class="d-flex flex-wrap gap-2">
        <Tag Variant="Tag.TagVariant.Primary">Primary</Tag>
        <Tag Variant="Tag.TagVariant.Success">Success</Tag>
        <Tag Variant="Tag.TagVariant.Danger">Danger</Tag>
        <Tag Variant="Tag.TagVariant.Warning">Warning</Tag>
        <Tag Variant="Tag.TagVariant.Info">Info</Tag>
        <Tag Variant="Tag.TagVariant.Secondary" Closable="true" OnClose="OnTagClose">Closable</Tag>
    </div>
</section>

<section class="mb-5">
    <h4>Timeline</h4>
    <Timeline Items="@TimelineItems" />
</section>

<section class="mb-5">
    <h4>Tour</h4>
    <Button Variant="Button.ButtonVariant.Primary" OnClick="StartTour">Start Tour</Button>
    <Tour @ref="_tour" Visible="@TourVisible" Title="Component Tour" Step="@TourStep" TotalSteps="@TourSteps.Count" OnClose="EndTour" OnNext="NextTourStep" OnPrev="PrevTourStep">
        @if (TourStep < TourSteps.Count)
        {
            <p>@TourSteps[TourStep]</p>
        }
    </Tour>
</section>

<section class="mb-5">
    <h4>Drawer</h4>
    <Button Variant="Button.ButtonVariant.Primary" OnClick="OpenDrawer">Open Drawer</Button>
    <Drawer @ref="_drawer" Visible="@DrawerVisible" Title="Drawer Title" Placement="Drawer.DrawerPlacement.Left" OnClose="() => DrawerVisible = false">
        <ChildContent>
            <p>This is drawer content.</p>
        </ChildContent>
        <Footer>
            <Button Variant="Button.ButtonVariant.Secondary" Size="Button.ButtonSize.Small" OnClick="() => DrawerVisible = false">Close</Button>
        </Footer>
    </Drawer>
</section>

<section class="mb-5">
    <h4>Progress</h4>
    <div class="d-flex flex-column gap-3" style="max-width: 400px;">
        <Progress Value="@ProgressValue" Max="100" ShowLabel="true" />
        <Progress Value="@ProgressValue2" Max="200" ShowLabel="true" Label="Uploading..." />
    </div>
</section>

<section class="mb-5">
    <h4>Skeleton</h4>
    <div class="row g-3">
        <div class="col-md-6">
            <Skeleton Variant="Skeleton.SkeletonVariant.Text" Lines="3" />
        </div>
        <div class="col-md-6">
            <Skeleton Variant="Skeleton.SkeletonVariant.Rectangle" Width="100%" Height="120px" />
        </div>
        <div class="col-md-4">
            <Skeleton Variant="Skeleton.SkeletonVariant.Circle" />
        </div>
        <div class="col-md-4">
            <Skeleton Variant="Skeleton.SkeletonVariant.Image" />
        </div>
        <div class="col-md-4">
            <Skeleton Variant="Skeleton.SkeletonVariant.Button" />
        </div>
    </div>
</section>

<Toaster Position="ToastPosition.TopRight" />
