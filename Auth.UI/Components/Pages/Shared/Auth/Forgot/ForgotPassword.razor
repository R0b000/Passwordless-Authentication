@page "/forgot-password"
@namespace Auth.UI.Components.Pages.Shared.Forgot
@layout LoginLayout
@using Auth.UI.Components.UI.Toaster
@using Auth.UI.Components.UI.Icons

<PageTitle>Forgot password - Passwordless Auth</PageTitle>

<section class="lp-panel">
    <div class="lp-card">
        <h1 class="lp-title">Reset your password</h1>
        <p class="lp-sub">Enter your email and we'll send a reset link.</p>

        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            <div class="lp-alert @(Succeeded ? "lp-alert-success" : "lp-alert-danger")" role="alert">@StatusMessage</div>
        }

        <div class="lp-field">
            <label class="lp-label" for="fp-email">Email</label>
            <div class="lp-input">
                <Icon Name="user" Size="Icon.IconSize.Small" />
                <input id="fp-email" type="email" class="lp-control" @bind="Email" placeholder="name@example.com" />
            </div>
        </div>

        <Button Variant="Button.ButtonVariant.Primary" Block="true" OnClick="SubmitAsync">Send reset link</Button>

        <div class="lp-divider"><span>or</span></div>
        <p class="text-center mb-0">Remembered it? <a href="/login">Sign in</a></p>
    </div>
</section>

<Toaster Position="ToastPosition.TopRight" />
