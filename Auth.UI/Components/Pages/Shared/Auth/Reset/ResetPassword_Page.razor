@page "/reset-password"
@namespace Auth.UI.Components.Pages.Shared.Reset
@layout LoginLayout
@using global::Shared.UI.Components.Toaster
@using global::Shared.UI.Components.Icons
@using Microsoft.AspNetCore.Components

<PageTitle>Reset password - Passwordless Auth</PageTitle>

<section class="lp-panel">
    <div class="lp-card">
        <h1 class="lp-title">Choose a new password</h1>
        <p class="lp-sub">Enter the code from your email and set a new password.</p>

        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            <div class="lp-alert @(Succeeded ? "lp-alert-success" : "lp-alert-danger")" role="alert">@StatusMessage</div>
        }

        <div class="lp-field">
            <label class="lp-label" for="rp-token">Reset code</label>
            <div class="lp-input">
                <Icon Name="key" Size="Icon.IconSize.Small" />
                <input id="rp-token" class="lp-control" @bind="Token" placeholder="123456" />
            </div>
        </div>

        <div class="lp-field">
            <label class="lp-label" for="rp-pw">New password</label>
            <div class="lp-input">
                <Icon Name="lock" Size="Icon.IconSize.Small" />
                <input id="rp-pw" type="@(ShowPassword ? "text" : "password")" class="lp-control" @bind="NewPassword" placeholder="New password" />
            </div>
        </div>

        <div class="lp-field">
            <label class="lp-label" for="rp-pwc">Confirm new password</label>
            <div class="lp-input">
                <Icon Name="lock" Size="Icon.IconSize.Small" />
                <input id="rp-pwc" type="@(ShowPassword ? "text" : "password")" class="lp-control" @bind="ConfirmPassword" placeholder="Repeat password" />
            </div>
        </div>

        <Button Variant="Button.ButtonVariant.Primary" Block="true" OnClick="SubmitAsync">Reset password</Button>

        <div class="lp-divider"><span>or</span></div>
        <p class="text-center mb-0">Back to <a href="/login">Sign in</a></p>
    </div>
</section>

<Toaster Position="ToastPosition.TopRight" />
