@page "/"
@namespace Auth.UI.Components.Pages
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer

<PageTitle>Sign in - Passwordless Auth</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <h1 class="mb-4">Passwordless Auth</h1>

        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            <div class="alert @(Succeeded ? "alert-success" : "alert-danger")" role="alert">@StatusMessage</div>
        }

        <ul class="nav nav-tabs mb-3" role="tablist">
            <li class="nav-item">
                <button class="nav-link @(Mode == "login" ? "active" : "")" @onclick="@(() => Mode = "login")" type="button">Login</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(Mode == "register" ? "active" : "")" @onclick="@(() => Mode = "register")" type="button">Register</button>
            </li>
        </ul>

        @if (Mode == "login")
        {
            <EditForm Model="@LoginModel" OnValidSubmit="@LoginAsync" FormName="login">
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <InputText class="form-control" @bind-Value="LoginModel.Username" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <InputText type="password" class="form-control" @bind-Value="LoginModel.Password" />
                </div>
                <button type="submit" class="btn btn-primary w-100">Login</button>
            </EditForm>

            @if (RequiresFido2)
            {
                <div class="mt-3 d-flex flex-column gap-2">
                    <button class="btn btn-outline-dark w-100" @onclick="@GoToFido2" type="button">Continue with passkey</button>
                    
                    <hr />
                    
                    @if (!OtpRequested)
                    {
                        <button class="btn btn-outline-secondary w-100" @onclick="@RequestOtpAsync" type="button">Lost Passkey? Send Login OTP to Email</button>
                    }
                    else
                    {
                        <div class="border rounded p-3 bg-light text-start">
                            <label class="form-label font-weight-bold">Enter the OTP sent to your email:</label>
                            <InputText class="form-control mb-2" @bind-Value="OtpCode" placeholder="6-digit OTP" />
                            <button class="btn btn-success w-100" @onclick="@VerifyOtpAsync" type="button">Verify OTP & Login</button>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <EditForm Model="@RegisterModel" OnValidSubmit="@RegisterAsync" FormName="register">
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <InputText class="form-control" @bind-Value="RegisterModel.Username" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText type="email" class="form-control" @bind-Value="RegisterModel.Email" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <InputText type="password" class="form-control" @bind-Value="RegisterModel.Password" />
                </div>
                <button type="submit" class="btn btn-primary w-100">Register</button>
            </EditForm>
        }
    </div>
</div>
