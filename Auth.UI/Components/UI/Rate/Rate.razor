@namespace Auth.UI.Components.UI.Rate

<div class="ui-rate @(Disabled ? "is-disabled" : "")" role="radiogroup" aria-label="@Label">
    @for (int i = 1; i <= Max; i++)
    {
        var value = i;
        <button class="ui-rate-star @(value <= CurrentValue ? "is-filled" : "")"
                type="button"
                aria-label="@value star@(value > 1 ? "s" : "")"
                aria-checked="@(value <= CurrentValue)"
                disabled="@Disabled"
                @onclick="@(() => SetValue(value))"
                @onmouseenter="@(() => HoverValue = Disabled ? (int?)null : value)"
                @onmouseleave="@(() => HoverValue = null)">
            ★
        </button>
    }
    @if (ShowText)
    {
        <span class="ui-rate-text">@CurrentValue / @Max</span>
    }
</div>
