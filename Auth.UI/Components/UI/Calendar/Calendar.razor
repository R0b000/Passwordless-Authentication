@namespace Auth.UI.Components.UI.Calendar

<div class="ui-calendar">
    <div class="ui-calendar-header">
        <button class="ui-icon-btn" @onclick="PrevMonth" aria-label="Previous month"><Icon Name="chevron-left" Size="Icon.IconSize.Small" /></button>
        <span class="ui-calendar-title">@Title</span>
        <button class="ui-icon-btn" @onclick="NextMonth" aria-label="Next month"><Icon Name="chevron-right" Size="Icon.IconSize.Small" /></button>
    </div>
    <div class="ui-calendar-grid">
        <div class="ui-calendar-week">
            @foreach (var day in DayNames)
            {
                <div class="ui-calendar-weekday">@day</div>
            }
        </div>
        <div class="ui-calendar-week">
            @foreach (var d in Days)
            {
                <button class="ui-calendar-day @(d.IsToday ? "is-today" : "") @(d.IsSelected ? "is-selected" : "") @(d.IsOtherMonth ? "is-other-month" : "")"
                        disabled="@Disabled" @onclick="@(() => Select(d))">
                    @d.Day
                </button>
            }
        </div>
    </div>
</div>
