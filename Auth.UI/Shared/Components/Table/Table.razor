@namespace Auth.UI.Components.UI.Table
@using Auth.UI.Shared.Components.Table
@typeparam TItem

<div class="ui-table-wrapper">
    <div class="ui-table-toolbar">
        @if (EnableFiltering)
        {
            <Button Variant="Button.ButtonVariant.Secondary" Size="Button.ButtonSize.Small" IconName="filter"
                    OnClick="@(() => ShowFilters = !ShowFilters)">Filter</Button>
        }
        @if (EnableColumnToggle)
        {
            <div class="ui-dropdown">
                <Button Variant="Button.ButtonVariant.Secondary" Size="Button.ButtonSize.Small" IconName="columns"
                        OnClick="@(() => ShowColumnToggle = !ShowColumnToggle)">Columns</Button>
                @if (ShowColumnToggle)
                {
                    <div class="ui-dropdown-menu" @onclick:stopPropagation>
                        @foreach (var col in Columns)
                        {
                            <label class="ui-dropdown-item">
                                <input type="checkbox" checked="@col.Visible" @onchange="@(e => ToggleColumn(col, e))" />
                                @col.Title
                            </label>
                        }
                    </div>
                }
            </div>
        }
        @if (ChildToolbar is not null)
        {
            @ChildToolbar
        }
    </div>

    @if (EnableFiltering && ShowFilters)
    {
        <div class="ui-table-filter-panel">
            @foreach (var f in Filters)
            {
                <div class="ui-filter-row">
                    <select class="ui-input" value="@f.Property" @onchange="@(e => OnFilterColumnChanged(f, e))">
                        <option value="">-- column --</option>
                        @foreach (var col in Columns.Where(c => c.Visible && c.Property is not null))
                        {
                            <option value="@col.Property">@col.Title</option>
                        }
                    </select>
                    <select class="ui-input" value="@f.Operator" @onchange="@(e => f.Operator = ParseOperator(e.Value))">
                        @foreach (var op in Enum.GetValues<FilterOperator>())
                        {
                            <option value="@op">@op.Label()</option>
                        }
                    </select>
                    @if (f.Operator is not FilterOperator.IsEmpty and not FilterOperator.IsNotEmpty)
                    {
                        <input class="ui-input" type="text" placeholder="value" value="@f.Value"
                               @oninput="@(e => OnFilterValueChanged(f, e))" />
                    }
                    <button type="button" class="ui-icon-btn" aria-label="Remove filter" @onclick="@(() => RemoveFilter(f))">
                        <Icon Name="trash" Size="Icon.IconSize.Small" />
                    </button>
                </div>
            }
            <div class="ui-filter-actions">
                <Button Variant="Button.ButtonVariant.Primary" Size="Button.ButtonSize.Small" IconName="plus"
                        OnClick="AddFilter">Add filter</Button>
                <Button Variant="Button.ButtonVariant.Light" Size="Button.ButtonSize.Small"
                        OnClick="ClearFilters">Clear</Button>
            </div>
        </div>
    }

    <div class="ui-table-scroll">
        <table class="ui-table">
            <thead>
                <tr>
                    @foreach (var col in VisibleColumns)
                    {
                        <th class="@(col.Sortable ? "sortable" : "")" @onclick="@(() => SortBy(col))">
                            <span class="ui-th-label">@col.Title</span>
                            @if (col.Sortable && SortColumn == col.Property)
                            {
                                <Icon Name="@(SortDescending ? "arrow-down" : "arrow-up")" Size="Icon.IconSize.Small" />
                            }
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (PagedItems.Count == 0)
                {
                    <tr>
                        <td class="ui-table-empty" colspan="@VisibleColumns.Count">No records found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in PagedItems)
                    {
                        <tr>
                            @foreach (var col in VisibleColumns)
                            {
                                <td>
                                    @if (col.Template is not null)
                                    {
                                        @col.Template(item)
                                    }
                                    else
                                    {
                                        @FormatValue(item, col)
                                    }
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (EnablePagination && FilteredItems.Count > 0)
    {
        <div class="ui-table-footer">
            <div class="ui-table-info">
                Showing @(StartIndex + 1)–@EndIndex of @FilteredItems.Count
            </div>
            <div class="ui-table-pager">
                <select class="ui-input ui-page-size" value="@PageSize" @onchange="@(e => ChangePageSize(e))">
                    @foreach (var s in PageSizes)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
                <button type="button" class="ui-icon-btn" disabled="@(CurrentPage == 1)" @onclick="FirstPage"><Icon Name="chevron-left" Size="Icon.IconSize.Small" /></button>
                <button type="button" class="ui-icon-btn" disabled="@(CurrentPage == 1)" @onclick="PrevPage"><Icon Name="chevron-left" Size="Icon.IconSize.Small" /></button>
                <span class="ui-page-indicator">@CurrentPage / @TotalPages</span>
                <button type="button" class="ui-icon-btn" disabled="@(CurrentPage == TotalPages)" @onclick="NextPage"><Icon Name="chevron-right" Size="Icon.IconSize.Small" /></button>
                <button type="button" class="ui-icon-btn" disabled="@(CurrentPage == TotalPages)" @onclick="LastPage"><Icon Name="chevron-right" Size="Icon.IconSize.Small" /></button>
            </div>
        </div>
    }
</div>
